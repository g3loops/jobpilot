# Copy this file to ".env" and fill in your real values.
# .env is git-ignored and excluded from the submission ZIP — credentials never get submitted.

# Adzuna API (live job postings bonus) — get these from https://developer.adzuna.com  -> Access Details
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# Optional: Anthropic key for LLM-based resume / cover-letter generation.
# If absent, JobPilot falls back to a high-quality template generator (still fully functional).
ANTHROPIC_API_KEY=
